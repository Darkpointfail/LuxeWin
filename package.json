{
  "name": "gaviom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next node_modules/.cache",
    "dev": "NEXT_TELEMETRY_DISABLED=1 next dev",
    "dev:turbo": "NEXT_TELEMETRY_DISABLED=1 next dev --turbo",
    "dev:webpack": "NEXT_TELEMETRY_DISABLED=1 next dev",
    "dev:reset": "npm run clean && npm run dev",
    "dev:clean": "echo \"⚠ Use dev:reset only when the app is broken — it forces a full recompile.\" && npm run dev:reset",
    "dev:fresh": "npm run dev:reset",
    "dev:webpack:clean": "npm run dev:reset",
    "dev:turbo:clean": "npm run clean && next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
